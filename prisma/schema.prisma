// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// User profile linked to Supabase Auth (auth.users)
model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  fullName    String?  @map("full_name") @db.VarChar(255)
  avatarUrl   String?  @map("avatar_url") @db.Text
  bio         String?  @db.Text
  location    String?  @db.VarChar(255)
  website     String?  @db.VarChar(500)
  linkedinUrl String?  @map("linkedin_url") @db.VarChar(500)
  githubUrl   String?  @map("github_url") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  applications JobApplication[]
  resumes      Resume[]

  @@index([userId])
  @@map("profiles")
}

/// Job application tracking
model JobApplication {
  id          String            @id @default(uuid())
  profileId   String            @map("profile_id")
  companyName String            @map("company_name") @db.VarChar(255)
  jobTitle    String            @map("job_title") @db.VarChar(255)
  jobUrl      String?           @map("job_url") @db.Text
  location    String?           @db.VarChar(255)
  salary      String?           @db.VarChar(100)
  status      ApplicationStatus @default(DRAFT)
  notes       String?           @db.Text
  appliedAt   DateTime?         @map("applied_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@index([createdAt])
  @@map("job_applications")
}

/// User resumes
model Resume {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  title     String   @db.VarChar(255)
  content   String?  @db.Text
  fileUrl   String?  @map("file_url") @db.Text
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("resumes")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ApplicationStatus {
  DRAFT
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}
